{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "incremental": false,
    "plugins": []
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", ".next", "**/*.test.ts", "**/*.test.tsx"]
}
