{
    "name": "@gsknnft/skill-ui",
    "version": "0.1.0",
    "description": "React skill manager and security workbench components for the skill-suite.",
    "private": false,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "style": "dist/styles.css",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./styles.css": "./dist/styles.css",
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "docs",
        "README.md",
        "CHANGELOG.md",
        "CONTRIBUTING.md",
        "SECURITY.md",
        "LICENSE",
        "package.json"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/gsknnft/skill-ui.git"
    },
    "author": "Gsknnft",
    "license": "MIT",
    "keywords": [
        "agent",
        "skills",
        "skill-manager",
        "skill-suite",
        "skill-safe",
        "skill-ledger",
        "ui",
        "components"
    ],
    "scripts": {
        "build": "pnpm clean && tsc -p tsconfig.build.json && node -e \"require('node:fs').copyFileSync('src/styles.css','dist/styles.css')\"",
        "dev": "next dev",
        "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
        "lint": "eslint 'src/**/*.{ts,tsx}'",
        "test": "vitest run src",
        "demo": "next dev",
        "pack:check": "pnpm pack --dry-run"
    },
    "dependencies": {},
    "devDependencies": {
        "@vitejs/plugin-react": "^6.0.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "next": "16.2.4",
        "react": "19.2.5",
        "react-dom": "^19.2.5",
        "typescript": "^5.9.3",
        "vite": "8.0.10",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "@gsknnft/skill-safe": "^0.3.0",
        "react": ">=18.3.0 <20",
        "react-dom": ">=18.3.0 <20"
    }
}
