{
    "name": "@gsknnft/skill-ui",
    "version": "0.1.0",
    "description": "UI components for agent skills",
    "private": false,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/gsknnft/skill-ui.git"
    },
    "author": "Gsknnft",
    "license": "MIT",
    "keywords": [
        "agent",
        "skills",
        "ui",
        "components"
    ],
    "scripts": {
        "build": "pnpm clean && tsc -p tsconfig.build.json",
        "start": "next dev",
        "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
        "lint": "eslint 'src/**/*.{ts,tsx}'",
        "test": "vitest run src"
    },
    "dependencies": {
        "@gsknnft/skill-safe": "link:../skill-safe",
        "@gsknnft/skill-ledger": "link:../skill-ledger",
        "next": "16.2.4",
        "react": "19.2.5",
        "react-dom": "^19.2.5",
        "vite": "8.0.10"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^6.0.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "typescript": "^5.9.3",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    }
}
